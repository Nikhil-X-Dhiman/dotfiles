{
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "Night Owl",
  "editor.fontSize": 16,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "'FiraCode Nerd Font', 'Droid Sans Mono', 'monospace', monospace",
  "editor.wordWrap": "on",
  "editor.tabSize": 2,
  "editor.formatOnPaste": true,
  "editor.autoIndentOnPaste": true,
  "editor.foldingImportsByDefault": true,
  "editor.guides.bracketPairs": "active",
  "editor.selectionHighlightMultiline": true,
  "editor.smoothScrolling": true,
  "editor.tabCompletion": "on",
  "editor.trimWhitespaceOnDelete": true,
  "editor.unfoldOnClickAfterEndOfLine": true,
  "editor.unicodeHighlight.includeComments": true,
  "editor.unicodeHighlight.nonBasicASCII": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.find.autoFindInSelection": "multiline",
  "editor.fontLigatures": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.fontWeight": "400",
  "editor.definitionLinkOpensInPeek": true,
  "diffEditor.codeLens": true,
  "editor.minimap.enabled": false,
  "editor.suggest.preview": true,
  "editor.suggest.localityBonus": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 300000,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "workbench.commandPalette.experimental.enableNaturalLanguageSearch": false,
  "workbench.enableExperiments": false,
  "workbench.list.smoothScrolling": true,
  "workbench.reduceMotion": "off",
  "workbench.remoteIndicator.showExtensionRecommendations": false,
  "workbench.preferredDarkColorTheme": "Andromeda",
  "workbench.sideBar.location": "right",
  "workbench.tips.enabled": false,
  "workbench.view.showQuietly": {
    "workbench.panel.output": true,
  },
  "window.controlsStyle": "custom",
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "compact",
  "window.menuStyle": "custom",
  "accessibility.openChatEditedFiles": true,
  "accessibility.underlineLinks": true,
  "explorer.incrementalNaming": "smart",
  "search.quickAccess.preserveInput": true,
  "search.searchView.semanticSearchBehavior": "runOnEmpty",
  "search.searchView.keywordSuggestions": true,
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "extensions.ignoreRecommendations": true,
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "line",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontWeight": "400",
  "terminal.integrated.fontWeightBold": "600",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.suggest.insertTrailingSpace": true,
  "chat.editor.fontSize": 15,
  "chat.fontSize": 14,
  "telemetry.editStats.enabled": false,
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "better-comments.highlightPlainText": true,
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "?",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "//",
      "color": "#474747",
      "strikethrough": true,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "todo",
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "*",
      "color": "#98C379",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
  ],
  "C_Cpp.autocompleteAddParentheses": true,
  "C_Cpp.inlayHints.autoDeclarationTypes.enabled": true,
  "C_Cpp.inlayHints.autoDeclarationTypes.showOnLeft": true,
  "C_Cpp.inlayHints.parameterNames.enabled": true,
  "C_Cpp.inlayHints.referenceOperator.enabled": true,
  "C_Cpp.vcFormat.indent.braces": true,
  "C_Cpp.vcFormat.indent.accessSpecifiers": true,
  "C_Cpp.vcFormat.indent.caseContentsWhenBlock": true,
  "C_Cpp.vcFormat.indent.caseLabels": true,
  "css.format.spaceAroundSelectorSeparator": true,
  "css.lint.float": "warning",
  "css.lint.important": "warning",
  "css.lint.importStatement": "warning",
  "errorLens.statusBarIconsEnabled": true,
  "gitignore.cacheExpirationInterval": 7200,
  "npm-intellisense.scanDevDependencies": true,
  "prettier.singleQuote": true,
  "prettier.singleAttributePerLine": true,
  "code-runner.runInTerminal": true,
  "code-runner.ignoreSelection": true,
  "code-runner.preserveFocus": false,
  "code-runner.saveFileBeforeRun": true,
  "tailwindCSS.emmetCompletions": true,
  "javascript.referencesCodeLens.enabled": false,
  "js/ts.implicitProjectConfig.checkJs": true,
  "typescript.implementationsCodeLens.enabled": true,
  "typescript.implementationsCodeLens.showOnInterfaceMethods": true,
  "typescript.referencesCodeLens.enabled": false,
  "javascript.suggest.completeFunctionCalls": true,
  "typescript.suggest.completeFunctionCalls": true,
  "javascript.format.semicolons": "insert",
  "javascript.format.enable": false,
  "typescript.format.enable": false,
  "typescript.format.semicolons": "insert",
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.parameterNames.enabled": "all",
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "yaml.extension.recommendations": false,
  "yaml.format.enable": false,
  "errorLens.enableOnDiffView": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "typescriptreact": false,
  },
  "editor.inertialScroll": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "window.customTitleBarVisibility": "windowed",
  "git.autofetch": true,
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/dist/**": true,
    "**/.git/**": true,
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
  },
  "chat.useAgentSkills": true,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font'",
  "comments.openView": "never",
  "http.systemCertificatesNode": true,
  "geminicodeassist.project": "powerful-defender-b00gw",
  "aws.telemetry": false,
  "aws.cloudformation.telemetry.enabled": false,
  "git.openRepositoryInParentFolders": "always",
}
