# ==============================================================================
# [1] PLUGIN MANAGEMENT & CORE INTERFACE (ZSH PORTABILITY REMARKS)
# ==============================================================================
# NOTE: Antidote is a Zsh-native plugin manager and cannot run in Bash.
# If you want plugin management in Bash, consider installing Oh My Bash
# (https://github.com/ohmybash/oh-my-bash) or Bash-it (https://github.com/bash-it/bash-it).
#
# The following Zsh-specific completion setup cannot be ported directly:
#   - antidote load
#   - zstyle :compinstall ...
#   - autoload -Uz compinit; compinit
#   - Zsh Line Editor (zle) autoloads/bindings for up-line-or-beginning-search
#
# Instead, standard Bash programmable completion is enabled at the end of this file,
# and keybindings are handled via Readline 'bind' commands in Section [3].

# ==============================================================================
# [2] SHELL ENVIRONMENT & HARDENED HISTORY CONFIGURATION
# ==============================================================================
HISTFILE=~/.bash_history
HISTSIZE=500000
HISTFILESIZE=500000

# Bash history settings:
# - histappend: append to the history file, don't overwrite it
shopt -s histappend

# - HISTCONTROL: ignoreboth (ignorespace + ignoredups), erasedups (delete duplicates)
# This covers HIST_IGNORE_DUPS, HIST_IGNORE_ALL_DUPS, HIST_IGNORE_SPACE, HIST_SAVE_NO_DUPS
HISTCONTROL=ignoreboth:erasedups

# - HISTTIMEFORMAT: Write/display timestamps (similar to Zsh EXTENDED_HISTORY format)
HISTTIMEFORMAT="%F %T "

# - SHARE_HISTORY simulation in Bash:
# Append history after each command and re-read it before displaying prompt.
PROMPT_COMMAND="history -a; history -c; history -r; ${PROMPT_COMMAND:+${PROMPT_COMMAND};}"

# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize

# make less more friendly for non-text input files, see lesspipe(1)
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# set variable identifying the chroot you work in (used in the prompt below)
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

# ==============================================================================
# [3] TERMINAL KEYBINDINGS MATRIX
# ==============================================================================
set -o emacs                       # Enforce standard Emacs execution bindings

# Interactive history query search bindings (Up/Down arrow parameters)
bind '"\e[A": history-search-backward'
bind '"\e[B": history-search-forward'

# Standard cursor and inline manipulation mapping fixes
bind '"\e[3~": delete-char'               # Delete key
bind '"\e[H": beginning-of-line'          # Home key standard variant A
bind '"\e[1~": beginning-of-line'         # Home key standard variant B
bind '"\eOH": beginning-of-line'          # Home key alternate map
bind '"\e[F": end-of-line'                # End key standard variant A
bind '"\e[4~": end-of-line'               # End key standard variant B
bind '"\eOF": end-of-line'                # End key alternate map

# Cursor manipulation bindings via Ctrl key vectors
bind '"\e[1;5C": forward-word'            # Ctrl + Right Arrow
bind '"\e[1;5D": backward-word'           # Ctrl + Left Arrow
bind '"\C-h": backward-kill-word'         # Ctrl + Backspace
bind '"\e[3;5~": kill-word'               # Ctrl + Delete

# ==============================================================================
# [4] RUNTIME ENGINE ARCHITECTURE & PATH ROUTING
# ==============================================================================
# NUCLEAR PATH CLEANSER: Drops ALL Windows paths (/mnt/c/*) to stop autocomplete
# stutters and .dll leaks, while surgically preserving only Microsoft VS Code.
_clean_path=""
_old_ifs="$IFS"
IFS=":"
for env_path in $PATH; do
    if [[ "$env_path" != /mnt/c/* ]] || [[ "$env_path" =~ "Microsoft VS Code" ]]; then
        if [[ -z "$_clean_path" ]]; then
            _clean_path="$env_path"
        else
            _clean_path="$_clean_path:$env_path"
        fi
    fi
done
IFS="$_old_ifs"
export PATH="$_clean_path"
unset _clean_path _old_ifs env_path

# Inject local user binary paths securely
export PATH="$HOME/.local/bin:$HOME/bin:/usr/local/bin:$PATH"

# Node Package Manager (pnpm) Environment Configuration
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# Node Version Manager (nvm) Initialization Sequence
export NVM_DIR="$HOME/.nvm"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    source "$NVM_DIR/nvm.sh" --no-use
    # Safely bundle companion utilities inside the activation guard
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
fi

# Safe initialization for Kubernetes infrastructure contexts
if command -v kubectl &>/dev/null; then
    source <(kubectl completion bash)
fi

# ==============================================================================
# [5] AUTOMATED CROSS-DISTRO PACMAN SHORTCUTS
# ==============================================================================
# Intelligently detects and maps the host platform's package controller architecture
if command -v nala &>/dev/null; then
    alias update='sudo nala update && sudo nala upgrade -y'
    alias install='sudo nala install -y'
    alias remove='sudo nala remove -y'
    alias search='nala search'
    alias clean='sudo nala autoremove -y && sudo nala clean'
elif command -v apt &>/dev/null; then
    alias update='sudo apt update && sudo apt upgrade -y'
    alias install='sudo apt install -y'
    alias remove='sudo apt remove -y'
    alias search='apt search'
    alias clean='sudo apt clean && sudo apt autoremove -y'
elif command -v dnf &>/dev/null; then
    alias update='sudo dnf upgrade --refresh -y'
    alias install='sudo dnf install -y'
    alias remove='sudo dnf remove -y'
    alias search='dnf search'
    alias clean='sudo dnf clean all'
elif command -v nix-env &>/dev/null; then
    alias update='nix-channel --update && nix-env -u'
    alias install='nix-env -iA'
    alias remove='nix-env -e'
    alias search='nix-env -qaP'
    alias clean='nix-store --gc'
fi

