# Directory Generation and Instantiated Entry Pipeline
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Cross-Platform IDE Execution Bridge for Windows Subsystem Contexts
agy() {
    if [[ ! -v WSL_DISTRO_NAME ]]; then
        echo "Error: This execution matrix is specifically optimized for WSL instances."
        return 1
    fi

    local DISTRO=$WSL_DISTRO_NAME
    local WIN_USER
    # Preserves the literal space in your username by only stripping the carriage return
    WIN_USER=$(/mnt/c/WINDOWS/System32/cmd.exe /c "echo %USERNAME%" 2>/dev/null | tr -d '\r')

    if [[ -z "$WIN_USER" ]]; then
        echo "Error: Failed to fetch host execution workspace profile identity parameters."
        return 1
    fi

    # EXACT PATH: Mapped directly to your Windows system install
    local AG_EXE="/mnt/c/Users/${WIN_USER}/AppData/Local/Programs/Antigravity IDE/Antigravity IDE.exe"
    local TARGET="${1:-.}"
    local ABS_PATH
    ABS_PATH=$(readlink -f "$TARGET")

    if [[ -f "$AG_EXE" ]]; then
        # SURGICALLY SILENCED in Bash: '& disown' releases the prompt cleanly (replaces Zsh's '&!')
        "$AG_EXE" --remote wsl+"$DISTRO" "$ABS_PATH" > /dev/null 2>&1 & disown
    else
        echo "Error: Could not locate Antigravity IDE Windows binary dependencies."
        echo "Attempted search target:"
        echo "  - $AG_EXE"
        return 1
    fi
}

# ==============================================================================
# [8] CONSOLE ENGINE SHELL EVALUATION INITIALIZATION
# ==============================================================================
# Fallback classic colored prompt logic (in case Starship isn't active/installed)
case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac

if [ "$color_prompt" = yes ]; then
    PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='${debian_chroot:+($debian_chroot)}\u@\h:\w\$ '
fi
unset color_prompt

# If this is an xterm set the title to user@host:dir
case "$TERM" in
xterm*|rxvt*)
    PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
    ;;
esac

# Enable programmable completion features (standard Bash completion)
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# Keep these modules strictly configured at the base of the runtime file
if command -v starship &>/dev/null; then
    eval "$(starship init bash)"
fi

if command -v zoxide &>/dev/null; then
    eval "$(zoxide init bash)"
fi

# Displays environmental context layout upon terminal instance deployment
if command -v fastfetch &>/dev/null; then
    fastfetch
fi
