# Directory Generation and Instantiated Entry Pipeline
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Cross-Platform IDE Execution Bridge for Windows Subsystem Contexts
agy() {
    if [[ ! -v WSL_DISTRO_NAME ]]; then
        echo "Error: This execution matrix is specifically optimized for WSL instances."
        return 1
    fi

    local DISTRO=$WSL_DISTRO_NAME
    local WIN_USER
    # Preserves the literal space in your username by only stripping the carriage return
    WIN_USER=$(/mnt/c/WINDOWS/System32/cmd.exe /c "echo %USERNAME%" 2>/dev/null | tr -d '\r')

    if [[ -z "$WIN_USER" ]]; then
        echo "Error: Failed to fetch host execution workspace profile identity parameters."
        return 1
    fi

    # EXACT PATH: Mapped directly to your Windows system install
    local AG_EXE="/mnt/c/Users/${WIN_USER}/AppData/Local/Programs/Antigravity IDE/Antigravity IDE.exe"
    local TARGET="${1:-.}"
    local ABS_PATH
    ABS_PATH=$(readlink -f "$TARGET")

    if [[ -f "$AG_EXE" ]]; then
        # SURGICALLY SILENCED: > /dev/null 2>&1 swallows all logs, &! releases the prompt cleanly
        "$AG_EXE" --remote wsl+"$DISTRO" "$ABS_PATH" > /dev/null 2>&1 &!
    else
        echo "Error: Could not locate Antigravity IDE Windows binary dependencies."
        echo "Attempted search target:"
        echo "  - $AG_EXE"
        return 1
    fi
}

