# ==============================================================================
#                      🚀 CORE DEVELOPMENT ENVIRONMENT OVERVIEW
# ==============================================================================
# To unlock the full engineering experience of this configuration, ensure the
# following core utilities are installed across your operating environments:
#
# 📋 CORE PREREQUISITES (Required for Basic Initialization):
#   1. Antidote  - High-performance, zsh-native plugin manager.
#                  Clone repo: git clone --depth=1 https://github.com/mattmc3/antidote.git ~/.antidote
#   2. Starship  - Cross-shell prompt engine (Engineered with two-line layout).
#   3. Zoxide    - Smart directory navigation engine (Smarter, predictive 'cd').
#   4. Fastfetch - Systems information layout visualizer.
#
# 🛠️ THE ULTIMATE DEV EXPERIENCE TOOLKIT (Highly Recommended Additions):
#   • fzf        - Command-line fuzzy finder. Essential for deep history lookups.
#   • lsd / eza  - Modern replacements for 'ls' with contextual tracking and icons.
#   • bat        - A 'cat' clone featuring syntax highlighting and git integration.
#   • ripgrep    - ('rg') Ultra-fast text orientation engine built to query deep project files.
#   • fd-find    - ('fd') A simple, fast, and user-friendly alternative to 'find'.
#   • tmux / zellij - Terminal workspaces with persistent multiplexer session state.
# ==============================================================================

# ==============================================================================
# [1] PLUGIN MANAGEMENT & CORE INTERFACE
# ==============================================================================
# Securely initialize Antidote without throwing errors if not yet pulled down
if [[ -f ~/.antidote/antidote.zsh ]]; then
    source ~/.antidote/antidote.zsh
    antidote load
fi

# Configuration metadata for the completion systems engine
zstyle :compinstall filename "$HOME/.zshrc"

autoload -Uz compinit
compinit -d "$HOME/.zcompdump" 2>/dev/null

# Load and bind smart substring history search modules
autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search

# ==============================================================================
# [2] SHELL ENVIRONMENT & HARDENED HISTORY CONFIGURATION
# ==============================================================================
HISTFILE=~/.zsh_history
HISTSIZE=500000
SAVEHIST=500000
# 📄 Unified VS Code Code Editor Variables
export EDITOR="code --wait"
export VISUAL="code --wait"

# Advanced shell execution adjustments
setopt EXTENDED_HISTORY          # Write the history file in the ':start:elapsed;cmd' format.
setopt SHARE_HISTORY             # Share history across running terminal sessions concurrently.
setopt HIST_EXPIRE_DUPS_FIRST    # Expire a duplicate event first when trimming history.
setopt HIST_IGNORE_DUPS          # Do not record an event that was just logged.
setopt HIST_IGNORE_ALL_DUPS      # Delete old duplicate entries when writing new entries.
setopt HIST_FIND_NO_DUPS         # Do not display a line previously found.
setopt HIST_IGNORE_SPACE         # Do not record an entry starting with a space.
setopt HIST_SAVE_NO_DUPS         # Do not write duplicate entries to the history file.

# ==============================================================================
# [3] TERMINAL KEYBINDINGS MATRIX
# ==============================================================================
bindkey -e                       # Enforce standard Emacs execution bindings

# Interactive history query search bindings (Up/Down arrow parameters)
bindkey "^[[A" up-line-or-beginning-search
bindkey "^[[B" down-line-or-beginning-search

# Standard cursor and inline manipulation mapping fixes
bindkey "^[[3~" delete-char               # Delete key
bindkey "^[[H" beginning-of-line          # Home key standard variant A
bindkey "^[[1~" beginning-of-line         # Home key standard variant B
bindkey "^[OH" beginning-of-line          # Home key alternate map
bindkey "^[[F" end-of-line                # End key standard variant A
bindkey "^[[4~" end-of-line               # End key standard variant B
bindkey "^[OF" end-of-line                # End key alternate map

# Cursor manipulation bindings via Ctrl key vectors
bindkey "^[[1;5C" forward-word            # Ctrl + Right Arrow
bindkey "^[[1;5D" backward-word           # Ctrl + Left Arrow
bindkey "^H" backward-kill-word           # Ctrl + Backspace
bindkey "^[[3;5~" kill-word               # Ctrl + Delete

# ==============================================================================
# [4] RUNTIME ENGINE ARCHITECTURE & PATH ROUTING
# ==============================================================================
# NUCLEAR PATH CLEANSER: Drops ALL Windows paths (/mnt/c/*) to stop autocomplete
# stutters and .dll leaks, while surgically preserving only Microsoft VS Code.
local clean_path=""
for env_path in ${(s.:.)PATH}; do
    if [[ "$env_path" != /mnt/c/* ]] || [[ "$env_path" =~ "Microsoft VS Code" ]]; then
        clean_path="${clean_path}:${env_path}"
    fi
done
export PATH="${clean_path#:}"

# Inject local user binary paths securely
export PATH="$HOME/.local/bin:$HOME/bin:/usr/local/bin:$PATH"

# Node Package Manager (pnpm) Environment Configuration
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# Node Version Manager (nvm) Initialization Sequence
export NVM_DIR="$HOME/.nvm"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    source "$NVM_DIR/nvm.sh" --no-use
    # Safely bundle companion utilities inside the activation guard
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
fi

# Safe initialization for Kubernetes infrastructure contexts
if type kubectl &>/dev/null; then
    source <(kubectl completion zsh)
fi

# ==============================================================================
# [5] AUTOMATED CROSS-DISTRO PACMAN SHORTCUTS
# ==============================================================================
# Intelligently detects and maps the host platform's package controller architecture
if (( $+commands[nala] )); then
    alias update='sudo nala update && sudo nala upgrade -y'
    alias install='sudo nala install -y'
    alias remove='sudo nala remove -y'
    alias search='nala search'
    alias clean='sudo nala autoremove -y && sudo nala clean'
elif (( $+commands[apt] )); then
    alias update='sudo apt update && sudo apt upgrade -y'
    alias install='sudo apt install -y'
    alias remove='sudo apt remove -y'
    alias search='apt search'
    alias clean='sudo apt clean && sudo apt autoremove -y'
elif (( $+commands[dnf] )); then
    alias update='sudo dnf upgrade --refresh -y'
    alias install='sudo dnf install -y'
    alias remove='sudo dnf remove -y'
    alias search='dnf search'
    alias clean='sudo dnf clean all'
elif (( $+commands[nix-env] )); then
    alias update='nix-channel --update && nix-env -u'
    alias install='nix-env -iA'
    alias remove='nix-env -e'
    alias search='nix-env -qaP'
    alias clean='nix-store --gc'
fi

